   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 4. Deterministic Business Logic\n",
    "\n",
    "Pure functions for verdict aggregation and borderline detection — testable, no LLM involved."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def aggregate_verdict(criteria: list[Union[CriterionResult, dict]]) -> str:\n",
    "    \"\"\"Compute overall eligibility verdict from per-criterion results.\n",
    "\n",
    "    Rules:\n",
    "    - Empty criteria list → needs_review (fail-safe: no evidence of eligibility)\n",
    "    - Any inclusion 'fail' → not_eligible\n",
    "    - Any exclusion 'fail' → not_eligible  (patient MEETS the exclusion criterion)\n",
    "    - Any 'unknown' (without disqualifier) → needs_review\n",
    "    - All inclusion 'pass' AND all exclusion 'pass' → eligible\n",
    "    \"\"\"\n",
    "    if not criteria:\n",
    "        return \"needs_review\"\n",
    "\n",
    "    has_unknown = False\n",
    "\n",
    "    for criterion in criteria:\n",
    "        if isinstance(criterion, dict):\n",
    "            ctype, outcome = criterion[\"type\"], criterion[\"outcome\"]\n",
    "        else:\n",
    "            ctype, outcome = criterion.type, criterion.outcome\n",
    "\n",
    "        if ctype == \"inclusion\" and outcome == \"fail\":\n",
    "            return \"not_eligible\"\n",
    "        if ctype == \"exclusion\" and outcome == \"fail\":\n",
    "            return \"not_eligible\"\n",
    "        if outcome == \"unknown\":\n",
    "            has_unknown = True\n",
    "\n",
    "    return \"needs_review\" if has_unknown else \"eligible\"\n",
    "\n",
    "\n",
    "def _is_numeric(value) -> bool:\n",
    "    if isinstance(value, (int, float)):\n",
    "        return True\n",
    "    if isinstance(value, str):\n",
    "        try:\n",
    "            float(value)\n",
    "            return True\n",
    "        except (ValueError, TypeError):\n",
    "            return False\n",
    "    return False\n",
    "\n",
    "\n",
    "def _extract_numeric(value) -> float | None:\n",
    "    \"\"\"Extract the leading numeric portion from a value, stripping units.\n",
    "\n",
    "    Handles values like \"30%\", \"850 pg/mL\", \"8.2%\", \"72%\", as well as plain\n",
    "    numbers. Returns None if no numeric portion can be parsed.\n",
    "    \"\"\"\n",
    "    if isinstance(value, (int, float)):\n",
    "        return float(value)\n",
    "    if isinstance(value, str):\n",
    "        match = re.match(r\"^\\s*([+-]?\\d+(?:\\.\\d+)?)\", value.strip())\n",
    "        if match:\n",
    "            try:\n",
    "                return float(match.group(1))\n",
    "            except ValueError:\n",
    "                pass\n",
    "    return None\n",
    "\n",
    "\n",
    "def compute_borderline_flag(\n",
    "    patient_profile: dict,\n",
    "    criteria_with_thresholds: list[dict],\n",
    ") -> bool:\n",
    "    \"\"\"Return True when patient is near any eligibility threshold.\n",
    "\n",
    "    - Age within 1 year of threshold → borderline\n",
    "    - Numeric biomarker within 10% of threshold → borderline\n",
    "    Unit suffixes (%, pg/mL, etc.) are stripped before comparison.\n",
    "    \"\"\"\n",
    "    age = patient_profile.get(\"age\")\n",
    "    biomarkers = patient_profile.get(\"biomarkers\") or {}\n",
    "\n",
    "    for criterion in criteria_with_thresholds:\n",
    "        age_threshold = criterion.get(\"age_threshold\")\n",
    "        if age is not None and age_threshold is not None:\n",
    "            if abs(age - age_threshold) <= 1:\n",
    "                return True\n",
    "\n",
    "        for name, threshold in (criterion.get(\"biomarker_thresholds\") or {}).items():\n",
    "            patient_value = biomarkers.get(name)\n",
    "            pv = _extract_numeric(patient_value)\n",
    "            tv = _extract_numeric(threshold)\n",
    "            if pv is None or tv is None:\n",
    "                continue\n",
    "            if tv == 0:\n",
    "                if abs(pv) <= 0:\n",
    "                    return True\n",
    "                continue\n",
    "            if abs(pv - tv) <= abs(tv) * 0.10:\n",
    "                return True\n",
    "\n",
    "    return False\n",
    "\n",
    "\n",
    "# Sanity checks\n",
    "assert aggregate_verdict([]) == \"needs_review\"\n",
    "assert aggregate_verdict([{\"type\": \"inclusion\", \"outcome\": \"pass\"}, {\"type\": \"exclusion\", \"outcome\": \"pass\"}]) == \"eligible\"\n",
    "assert aggregate_verdict([{\"type\": \"inclusion\", \"outcome\": \"fail\"}]) == \"not_eligible\"\n",
    "assert aggregate_verdict([{\"type\": \"exclusion\", \"outcome\": \"fail\"}]) == \"not_eligible\"\n",
    "assert aggregate_verdict([{\"type\": \"inclusion\", \"outcome\": \"unknown\"}]) == \"needs_review\"\n",
    "assert compute_borderline_flag({\"age\": 18, \"biomarkers\": {}}, [{\"age_threshold\": 18}]) == True\n",
    "assert compute_borderline_flag({\"age\": 30, \"biomarkers\": {}}, [{\"age_threshold\": 18}]) == False\n",
    "# Biomarker borderline checks with unit-bearing strings\n",
    "assert compute_borderline_flag({\"age\": 40, \"biomarkers\": {\"lvef\": \"30%\"}}, [{\"biomarker_thresholds\": {\"lvef\": 30}}]) == True\n",
    "assert compute_borderline_flag({\"age\": 40, \"biomarkers\": {\"bnp\": \"850 pg/mL\"}}, [{\"biomarker_thresholds\": {\"bnp\": 850}}]) == True\n",
    "assert compute_borderline_flag({\"age\": 40, \"biomarkers\": {\"hba1c\": \"8.2%\"}}, [{\"biomarker_thresholds\": {\"hba1c\": 10}}]) == False\n",
    "print(\"✅ Verdict aggregation and borderline logic verified.\")"
   ]
  },
