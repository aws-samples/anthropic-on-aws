   "source": [
    "### 5.1 get_patient_profile (in-memory lookup)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "@tool\n",
    "def get_patient_profile(patient_id: str) -> dict:\n",
    "    \"\"\"Retrieve a synthetic patient profile by patient_id.\n",
    "\n",
    "    Args:\n",
    "        patient_id: Unique identifier for the patient (e.g. \"P-003\").\n",
    "\n",
    "    Returns:\n",
    "        The patient profile dict on success, or an error dict if not found.\n",
    "    \"\"\"\n",
    "    profile = PATIENT_PROFILES.get(patient_id)\n",
    "    if profile is None:\n",
    "        return {\n",
    "            \"error_code\": \"PATIENT_NOT_FOUND\",\n",
    "            \"message\": f\"No patient profile found for patient_id '{patient_id}'.\",\n",
    "        }\n",
    "    return profile\n",
    "\n",
    "\n",
    "print(\"✅ get_patient_profile tool defined (in-memory, no DynamoDB).\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "### 5.2 search_trials (ClinicalTrials.gov API)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "_CT_API_URL = \"https://clinicaltrials.gov/api/v2/studies\"\n",
    "_TIMEOUT_SECONDS = 10\n",
    "_MAX_RESULTS = 20\n",
    "\n",
    "\n",
    "def split_eligibility_criteria(criteria_text: str) -> tuple[list[str], list[str]]:\n",
    "    \"\"\"Parse raw ClinicalTrials.gov eligibilityCriteria text into inclusion and exclusion lists.\n",
    "\n",
    "    The v2 API returns a single free-text block structured as:\n",
    "        Inclusion Criteria:\\n  * item\\nExclusion Criteria:\\n  * item\n",
    "    \"\"\"\n",
    "    inclusion, exclusion = [], []\n",
    "    if not criteria_text:\n",
    "        return inclusion, exclusion\n",
    "\n",
    "    # Split on the Exclusion Criteria header to separate the two sections\n",
    "    exc_pattern = re.compile(r\"exclusion\\s+criteria\\s*[:\\-]?\", re.IGNORECASE)\n",
    "    inc_pattern = re.compile(r\"inclusion\\s+criteria\\s*[:\\-]?\", re.IGNORECASE)\n",
    "\n",
    "    exc_match = exc_pattern.search(criteria_text)\n",
    "    if exc_match:\n",
    "        inc_block = criteria_text[:exc_match.start()]\n",
    "        exc_block = criteria_text[exc_match.end():]\n",
    "    else:\n",
    "        inc_block = criteria_text\n",
    "        exc_block = \"\"\n",
    "\n",
    "    # Strip the \"Inclusion Criteria:\" header from the inclusion block\n",
    "    inc_header = inc_pattern.search(inc_block)\n",
    "    if inc_header:\n",
    "        inc_block = inc_block[inc_header.end():]\n",
    "\n",
    "    def _parse_items(block: str) -> list[str]:\n",
    "        items = []\n",
    "        for line in block.splitlines():\n",
    "            line = re.sub(r\"^[\\s\\*\\-\\•\\d\\.]+\", \"\", line).strip()\n",
    "            if len(line) > 10:  # skip very short/empty lines\n",
    "                items.append(line)\n",
    "        return items\n",
    "\n",
    "    inclusion = _parse_items(inc_block)\n",
    "    exclusion = _parse_items(exc_block)\n",
    "    return inclusion, exclusion\n",
    "\n",
    "\n",
    "def _extract_locations(protocol_section: dict) -> list[str]:\n",
    "    locations_module = protocol_section.get(\"contactsLocationsModule\", {})\n",
    "    raw_locations = locations_module.get(\"locations\", [])\n",
    "    result = []\n",
    "    for loc in raw_locations:\n",
    "        parts = [loc.get(\"facility\", \"\"), loc.get(\"city\", \"\"),\n",
    "                 loc.get(\"state\", \"\"), loc.get(\"country\", \"\")]\n",
    "        result.append(\", \".join(p for p in parts if p))\n",
    "    return result\n",
    "\n",
    "\n",
    "def _transform_study(study: dict) -> dict:\n",
    "    protocol = study.get(\"protocolSection\", {})\n",
    "    id_module = protocol.get(\"identificationModule\", {})\n",
    "    design_module = protocol.get(\"designModule\", {})\n",
    "    status_module = protocol.get(\"statusModule\", {})\n",
    "    conditions_module = protocol.get(\"conditionsModule\", {})\n",
    "    eligibility_module = protocol.get(\"eligibilityModule\", {})\n",
    "    phases = design_module.get(\"phases\", [])\n",
    "\n",
    "    raw_criteria = eligibility_module.get(\"eligibilityCriteria\", \"\")\n",
    "    inclusion_criteria, exclusion_criteria = split_eligibility_criteria(raw_criteria)\n",
    "\n",
    "    return {\n",
    "        \"nct_id\": id_module.get(\"nctId\", \"\"),\n",
    "        \"title\": id_module.get(\"officialTitle\", id_module.get(\"briefTitle\", \"\")),\n",
    "        \"phase\": phases[0] if phases else \"N/A\",\n",
    "        \"status\": status_module.get(\"overallStatus\", \"\"),\n",
    "        \"conditions\": conditions_module.get(\"conditions\", []),\n",
    "        \"locations\": _extract_locations(protocol),\n",
    "        \"inclusion_criteria\": inclusion_criteria,\n",
    "        \"exclusion_criteria\": exclusion_criteria,\n",
    "    }\n",
    "\n",
    "\n",
    "@tool\n",
    "def search_trials(condition: str, location: str = None) -> dict | list[dict]:\n",
    "    \"\"\"Search ClinicalTrials.gov for recruiting trials matching a condition.\n",
    "\n",
    "    Args:\n",
    "        condition: Medical condition to search for (e.g. \"breast cancer\").\n",
    "        location: Optional geographic location to filter results.\n",
    "\n",
    "    Returns:\n",
    "        A list of trial summary dicts on success, or an error dict on failure.\n",
    "        Each dict includes inclusion_criteria and exclusion_criteria lists\n",
    "        parsed from the trial's eligibility module.\n",
    "    \"\"\"\n",
    "    params = {\n",
    "        \"query.cond\": condition,\n",
    "        \"filter.overallStatus\": \"RECRUITING|NOT_YET_RECRUITING\",\n",
    "        \"pageSize\": _MAX_RESULTS,\n",
    "    }\n",
    "    if location:\n",
    "        params[\"query.locn\"] = location\n",
    "\n",
    "    try:\n",
    "        response = requests.get(_CT_API_URL, params=params, timeout=_TIMEOUT_SECONDS)\n",
    "    except requests.exceptions.Timeout:\n",
    "        return {\"error_code\": \"TIMEOUT\", \"message\": f\"ClinicalTrials.gov did not respond within {_TIMEOUT_SECONDS} seconds.\"}\n",
    "    except requests.exceptions.RequestException as exc:\n",
    "        return {\"error_code\": \"REQUEST_ERROR\", \"message\": f\"Failed to reach ClinicalTrials.gov: {exc}\"}\n",
    "\n",
    "    if not response.ok:\n",
    "        return {\"error_code\": \"HTTP_ERROR\", \"status_code\": response.status_code,\n",
    "                \"message\": f\"ClinicalTrials.gov returned HTTP {response.status_code}: {response.text[:200]}\"}\n",
    "\n",
    "    studies = response.json().get(\"studies\", [])\n",
    "    return [_transform_study(s) for s in studies[:_MAX_RESULTS]]\n",
    "\n",
    "\n",
    "print(\"✅ search_trials tool defined (eligibility criteria extracted from API response).\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "### 5.3 retrieve_trial_kb (Knowledge Base — optional)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "@tool\n",
    "def retrieve_trial_kb(nct_id: str) -> dict:\n",
    "    \"\"\"Retrieve detailed trial eligibility criteria from the Bedrock Knowledge Base.\n",
    "\n",
    "    Args:\n",
    "        nct_id: ClinicalTrials.gov identifier (e.g. \"NCT01234567\").\n",
    "\n",
    "    Returns:\n",
    "        A dict with nct_id, content, and source_chunks on success,\n",
    "        or an error dict if KB is not configured or retrieval fails.\n",
    "    \"\"\"\n",
    "    if not KNOWLEDGE_BASE_ID:\n",
    "        return {\n",
    "            \"error_code\": \"KB_NOT_CONFIGURED\",\n",
    "            \"message\": \"Knowledge Base is not configured. The agent can proceed using search results only.\",\n",
    "        }\n",
    "\n",
    "    client = boto3.client(\"bedrock-agent-runtime\")\n",
    "\n",
    "    try:\n",
    "        response = client.retrieve(\n",
    "            knowledgeBaseId=KNOWLEDGE_BASE_ID,\n",
    "            retrievalQuery={\"text\": f\"trial {nct_id} eligibility criteria\"},\n",
    "            retrievalConfiguration={\"vectorSearchConfiguration\": {\"numberOfResults\": 10}},\n",
    "        )\n",
    "    except Exception as exc:\n",
    "        return {\"error_code\": \"KB_RETRIEVE_ERROR\", \"message\": f\"Failed to retrieve from Knowledge Base: {exc}\"}\n",
    "\n",
    "    results = response.get(\"retrievalResults\", [])\n",
    "    source_chunks = [r.get(\"content\", {}).get(\"text\", \"\") for r in results if r.get(\"content\", {}).get(\"text\")]\n",
    "\n",
    "    if not source_chunks:\n",
    "        return {\"error_code\": \"NO_RESULTS\", \"message\": f\"No Knowledge Base results found for trial {nct_id}.\"}\n",
    "\n",
    "    return {\"nct_id\": nct_id, \"content\": \"\\n\\n\".join(source_chunks), \"source_chunks\": source_chunks}\n",
    "\n",
    "\n",
    "print(\"✅ retrieve_trial_kb tool defined (gracefully degrades without KB).\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "### 5.4 evaluate_eligibility (Bedrock + deterministic logic)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def _build_eligibility_prompt(patient_profile: dict, inclusion_criteria: list[str], exclusion_criteria: list[str]) -> str:\n",
    "    criteria_block = \"\"\n",
    "    for c in inclusion_criteria:\n",
    "        criteria_block += f\"- [inclusion] {c}\\n\"\n",
    "    for c in exclusion_criteria:\n",
    "        criteria_block += f\"- [exclusion] {c}\\n\"\n",
    "\n",
    "    return f\"\"\"You are a clinical trial eligibility evaluator. Given a patient profile and a list of eligibility criteria, evaluate whether the patient meets each criterion.\n",
    "\n",
    "Patient Profile:\n",
    "{json.dumps(patient_profile, indent=2)}\n",
    "\n",
    "Eligibility Criteria:\n",
    "{criteria_block}\n",
    "\n",
    "For each criterion, determine the outcome:\n",
    "- \"pass\" if the patient clearly meets an inclusion criterion, or clearly does NOT meet an exclusion criterion\n",
    "- \"fail\" if the patient clearly does NOT meet an inclusion criterion, or clearly MEETS an exclusion criterion\n",
    "- \"unknown\" if there is insufficient information to determine the outcome\n",
    "\n",
    "Return ONLY a JSON array of objects. Each object must have exactly these keys:\n",
    "- \"criterion_text\": the original criterion text\n",
    "- \"type\": \"inclusion\" or \"exclusion\"\n",
    "- \"outcome\": \"pass\", \"fail\", or \"unknown\"\n",
    "- \"reasoning\": a brief explanation of why this outcome was assigned\n",
    "\n",
    "Return ONLY the JSON array, no other text.\"\"\"\n",
    "\n",
    "\n",
    "def _invoke_bedrock_for_eligibility(prompt: str) -> str:\n",
    "    client = boto3.client(\"bedrock-runtime\")\n",
    "    body = json.dumps({\n",
    "        \"anthropic_version\": \"bedrock-2023-05-31\",\n",
    "        \"max_tokens\": 4096,\n",
    "        \"messages\": [{\"role\": \"user\", \"content\": prompt}],\n",
    "    })\n",
    "    response = client.invoke_model(\n",
    "        modelId=MODEL_ID, contentType=\"application/json\",\n",
    "        accept=\"application/json\", body=body,\n",
    "    )\n",
    "    response_body = json.loads(response[\"body\"].read())\n",
    "    return response_body[\"content\"][0][\"text\"]\n",
    "\n",
    "\n",
    "def _parse_criteria_response(response_text: str) -> list[dict]:\n",
    "    text = response_text.strip()\n",
    "    try:\n",
    "        parsed = json.loads(text)\n",
    "        if isinstance(parsed, list):\n",
    "            return parsed\n",
    "    except json.JSONDecodeError:\n",
    "        pass\n",
    "    match = re.search(r\"```(?:json)?\\s*(\\[.*?])\\s*```\", text, re.DOTALL)\n",
    "    if match:\n",
    "        try:\n",
    "            return json.loads(match.group(1))\n",
    "        except json.JSONDecodeError:\n",
    "            pass\n",
    "    match = re.search(r\"\\[.*]\", text, re.DOTALL)\n",
    "    if match:\n",
    "        try:\n",
    "            return json.loads(match.group(0))\n",
    "        except json.JSONDecodeError:\n",
    "            pass\n",
    "    return []\n",
    "\n",
    "\n",
    "def _extract_age_threshold(criterion_text: str) -> int | None:\n",
    "    patterns = [\n",
    "        r\"[Aa]ge\\s*(?:>=?|<=?|≥|≤)\\s*(\\d+)\",\n",
    "        r\"(?:at least|minimum|older than|≥)\\s*(\\d+)\\s*(?:years|yrs)\",\n",
    "        r\"(\\d+)\\s*(?:years|yrs)\\s*(?:or older|of age|and older|and above)\",\n",
    "        r\"[Aa]ge.*?(\\d+)\\s*(?:years|yrs|$)\",\n",
    "    ]\n",
    "    for pattern in patterns:\n",
    "        match = re.search(pattern, criterion_text)\n",
    "        if match:\n",
    "            try:\n",
    "                return int(match.group(1))\n",
    "            except (ValueError, IndexError):\n",
    "                continue\n",
    "    return None\n",
    "\n",
    "\n",
    "def _build_criteria_with_thresholds(criterion_results: list[CriterionResult]) -> list[dict]:\n",
    "    thresholds = []\n",
    "    for cr in criterion_results:\n",
    "        entry = {}\n",
    "        age_threshold = _extract_age_threshold(cr.text)\n",
    "        if age_threshold is not None:\n",
    "            entry[\"age_threshold\"] = age_threshold\n",
    "        biomarker_matches = re.findall(r\"(\\w[\\w\\s]*?)\\s*(?:>=?|<=?|≥|≤|>|<|of)\\s*(\\d+(?:\\.\\d+)?)\", cr.text)\n",
    "        biomarker_thresholds = {}\n",
    "        for name, value in biomarker_matches:\n",
    "            name_lower = name.strip().lower()\n",
    "            if \"age\" in name_lower or \"year\" in name_lower:\n",
    "                continue\n",
    "            try:\n",
    "                biomarker_thresholds[name.strip().lower()] = float(value)\n",
    "            except ValueError:\n",
    "                continue\n",
    "        if biomarker_thresholds:\n",
    "            entry[\"biomarker_thresholds\"] = biomarker_thresholds\n",
    "        if entry:\n",
    "            thresholds.append(entry)\n",
    "    return thresholds\n",
    "\n",
    "\n",
    "@tool\n",
    "def evaluate_eligibility(patient_profile: dict, inclusion_criteria: list, exclusion_criteria: list) -> dict:\n",
    "    \"\"\"Evaluate a patient's eligibility against a clinical trial's criteria.\n",
    "\n",
    "    Uses Claude to assess each criterion, then applies deterministic\n",
    "    verdict aggregation, match score computation, and borderline flag detection.\n",
    "\n",
    "    Args:\n",
    "        patient_profile: The patient profile dict.\n",
    "        inclusion_criteria: List of inclusion criterion strings.\n",
    "        exclusion_criteria: List of exclusion criterion strings.\n",
    "\n",
    "    Returns:\n",
    "        An EligibilityAssessment dict with overall_verdict, overall_match_score,\n",
    "        criteria, and borderline_flag.\n",
    "    \"\"\"\n",
    "    if not inclusion_criteria and not exclusion_criteria:\n",
    "        return EligibilityAssessment(\n",
    "            overall_verdict=\"needs_review\",\n",
    "            overall_match_score=0.0,\n",
    "            borderline_flag=False,\n",
    "        ).to_dict()\n",
    "\n",
    "    prompt = _build_eligibility_prompt(patient_profile, inclusion_criteria, exclusion_criteria)\n",
    "\n",
    "    try:\n",
    "        response_text = _invoke_bedrock_for_eligibility(prompt)\n",
    "    except Exception as exc:\n",
    "        return {\"error_code\": \"BEDROCK_ERROR\", \"message\": f\"Failed to invoke Bedrock model: {exc}\"}\n",
    "\n",
    "    raw_criteria = _parse_criteria_response(response_text)\n",
    "    criterion_results = [\n",
    "        CriterionResult(\n",
    "            text=item.get(\"criterion_text\", \"\"),\n",
    "            type=item.get(\"type\", \"inclusion\"),\n",
    "            outcome=item.get(\"outcome\", \"unknown\"),\n",
    "            reasoning=item.get(\"reasoning\", \"\"),\n",
    "        )\n",
    "        for item in raw_criteria\n",
    "    ]\n",
    "\n",
    "    overall_verdict = aggregate_verdict(criterion_results)\n",
    "    overall_match_score = compute_match_score(criterion_results)\n",
    "    criteria_with_thresholds = _build_criteria_with_thresholds(criterion_results)\n",
    "    borderline_flag = compute_borderline_flag(patient_profile, criteria_with_thresholds)\n",
    "\n",
    "    assessment = EligibilityAssessment(\n",
    "        overall_verdict=overall_verdict,\n",
    "        overall_match_score=overall_match_score,\n",
    "        criteria=criterion_results,\n",
    "        borderline_flag=borderline_flag,\n",
    "    )\n",
    "    return assessment.to_dict()\n",
    "\n",
    "\n",
    "print(\"✅ evaluate_eligibility tool defined.\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 6. System Prompt & Agent Construction"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "SYSTEM_PROMPT = \"\"\"\\\n",
    "You are the Clinical Trial Matching Agent, a demonstration assistant that \\\n",
    "matches **synthetic** patient profiles to real, currently-recruiting clinical \\\n",
    "trials from ClinicalTrials.gov. This is an AWS reference implementation for \\\n",
    "educational purposes only.\n",
    "\n",
    "## Role\n",
    "You help demo users explore how agentic AI can match patients to clinical \\\n",
    "trials. You work exclusively with synthetic patient data and must never \\\n",
    "process real patient information.\n",
    "\n",
    "## Workflow\n",
    "Follow these steps for every matching request:\n",
    "\n",
    "1. **Fetch Patient Profile** — Call `get_patient_profile` with the supplied \\\n",
    "`patient_id` to retrieve the synthetic patient record. If the user provides \\\n",
    "a profile directly instead of an ID, use it as-is.\n",
    "2. **Search Trials** — Call `search_trials` with the patient's `condition` \\\n",
    "and `location` to find currently recruiting studies on ClinicalTrials.gov.\n",
    "3. **Retrieve Knowledge Base Documents** — For each candidate trial returned \\\n",
    "by the search, call `retrieve_trial_kb` with the trial's `nct_id` to obtain \\\n",
    "detailed eligibility criteria from the Knowledge Base. If the KB is not \\\n",
    "configured or returns an error, proceed using the search results alone.\n",
    "4. **Evaluate Eligibility** — For each candidate trial, call \\\n",
    "`evaluate_eligibility` with the patient profile and the trial's inclusion \\\n",
    "and exclusion criteria. This returns a per-criterion assessment with an \\\n",
    "overall verdict (`eligible`, `not_eligible`, or `needs_review`).\n",
    "5. **Rank and Return Top 5** — Rank trials by `overall_match_score` in \\\n",
    "descending order and return at most 5 Match Results as structured JSON.\n",
    "\n",
    "## Output Contract\n",
    "Return the ranked results as a JSON array embedded in your response. Each \\\n",
    "Match Result must include:\n",
    "- `nct_id`: the ClinicalTrials.gov identifier\n",
    "- `title`: the study title\n",
    "- `phase`: the trial phase\n",
    "- `location`: the trial location\n",
    "- `overall_match_score`: a float in [0, 1]\n",
    "- `eligibility_assessment`: the full per-criterion assessment\n",
    "- `borderline_flag`: boolean indicating proximity to an eligibility threshold\n",
    "\n",
    "Where `borderline_flag` is true, include a recommendation that the match \\\n",
    "should be reviewed by a physician.\n",
    "\n",
    "## Safety Rules\n",
    "- **Refuse real patient data.** If a request appears to describe a real, \\\n",
    "identifiable patient (e.g., contains a real name, date of birth, medical \\\n",
    "record number, or Social Security number), refuse the request and respond: \\\n",
    "\"I cannot process what appears to be real patient information. This demo \\\n",
    "works only with synthetic data. Please consult a physician for real clinical \\\n",
    "trial matching.\"\n",
    "- **Direct to physician.** Whenever a user asks for medical advice or seems \\\n",
    "to be making a real clinical decision, remind them to consult a qualified \\\n",
    "physician.\n",
    "\n",
    "## Disclaimer (REQUIRED)\n",
    "**Every response you produce MUST include the following disclaimer:**\n",
    "\n",
    "> ⚠️ **Disclaimer:** These matches are informational only and are generated \\\n",
    "> from synthetic patient data for demonstration purposes. They do not \\\n",
    "> constitute medical advice. A qualified physician must verify eligibility \\\n",
    "> before any clinical trial enrollment decisions are made.\n",
    "\n",
    "Never omit this disclaimer, even in follow-up or clarification responses.\n",
    "\"\"\"\n",
    "\n",
    "print(f\"System prompt: {len(SYSTEM_PROMPT)} chars\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Build the Strands Agent\n",
    "TOOLS = [get_patient_profile, search_trials, evaluate_eligibility, retrieve_trial_kb]\n",
    "\n",
bedrock_model = BedrockModel(model_id=MODEL_ID, max_tokens=8192)
    "agent = Agent(model=bedrock_model, tools=TOOLS, system_prompt=SYSTEM_PROMPT)\n",
    "\n",
    "print(\"✅ Agent created with tools:\")\n",
    "for t in TOOLS:\n",
    "    print(f\"   • {t.__name__}\")"
   ]
