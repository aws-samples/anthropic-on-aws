   "source": [
    "## 3. Data Models"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "@dataclass\n",
    "class CriterionResult:\n",
    "    \"\"\"Single per-criterion eligibility outcome.\"\"\"\n",
    "    text: str\n",
    "    type: str          # \"inclusion\" | \"exclusion\"\n",
    "    outcome: str       # \"pass\" | \"fail\" | \"unknown\"\n",
    "    reasoning: str\n",
    "\n",
    "    def to_dict(self) -> dict:\n",
    "        return asdict(self)\n",
    "\n",
    "\n",
    "@dataclass\n",
    "class EligibilityAssessment:\n",
    "    \"\"\"Full eligibility assessment for a patient against a trial.\"\"\"\n",
    "    overall_verdict: str        # \"eligible\" | \"not_eligible\" | \"needs_review\"\n",
    "    overall_match_score: float  # deterministic score in [0, 1]: pass=1.0, unknown=0.5, fail=0.0\n",
    "    criteria: list[CriterionResult] = field(default_factory=list)\n",
    "    borderline_flag: bool = False\n",
    "\n",
    "    def to_dict(self) -> dict:\n",
    "        return {\n",
    "            \"overall_verdict\": self.overall_verdict,\n",
    "            \"overall_match_score\": self.overall_match_score,\n",
    "            \"criteria\": [c.to_dict() for c in self.criteria],\n",
    "            \"borderline_flag\": self.borderline_flag,\n",
    "        }\n",
    "\n",
    "\n",
    "def compute_match_score(criteria: list[CriterionResult]) -> float:\n",
    "    \"\"\"Compute a deterministic match score in [0, 1] from per-criterion outcomes.\n",
    "\n",
    "    pass=1.0, unknown=0.5, fail=0.0 — averaged across all criteria.\n",
    "    Returns 0.0 for empty criteria lists.\n",
    "    \"\"\"\n",
    "    if not criteria:\n",
    "        return 0.0\n",
    "    weights = {\"pass\": 1.0, \"unknown\": 0.5, \"fail\": 0.0}\n",
    "    return sum(weights.get(c.outcome, 0.0) for c in criteria) / len(criteria)\n",
    "\n",
    "\n",
    "print(\"✅ Data models defined.\")"
   ]
  },
