  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 8. Display Results\n",
    "\n",
    "Parse and pretty-print structured Match Results from the agent's response."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def parse_match_results(response_text: str) -> list[dict]:\n",
    "    \"\"\"Extract Match Results JSON array from the agent response.\"\"\"\n",
    "    start = response_text.find(\"[\")\n",
    "    end = response_text.rfind(\"]\")\n",
    "    if start != -1 and end != -1 and end > start:\n",
    "        try:\n",
    "            return json.loads(response_text[start:end + 1])\n",
    "        except json.JSONDecodeError:\n",
    "            pass\n",
    "    return []\n",
    "\n",
    "\n",
    "def display_results(response_text: str) -> None:\n",
    "    \"\"\"Pretty-print match results.\"\"\"\n",
    "    results = parse_match_results(str(response_text))\n",
    "    if not results:\n",
    "        print(\"No structured results found. Raw response:\")\n",
    "        print(str(response_text)[:1000])\n",
    "        return\n",
    "\n",
    "    verdict_emoji = {\"eligible\": \"✅\", \"not_eligible\": \"❌\", \"needs_review\": \"🔍\"}\n",
    "    outcome_emoji = {\"pass\": \"✅\", \"fail\": \"❌\", \"unknown\": \"❓\"}\n",
    "\n",
    "    print(f\"\\n{'='*70}\")\n",
    "    print(f\"🏆 Top {min(len(results), 5)} Match Results\")\n",
    "    print(f\"{'='*70}\\n\")\n",
    "\n",
    "    for i, result in enumerate(results[:5], start=1):\n",
    "        score = result.get(\"overall_match_score\", 0)\n",
    "        assessment = result.get(\"eligibility_assessment\", {})\n",
    "        verdict = assessment.get(\"overall_verdict\", \"unknown\")\n",
    "\n",
    "        print(f\"{i}. {result.get('title', 'Untitled')}\")\n",
    "        print(f\"   NCT ID: {result.get('nct_id')} | Phase: {result.get('phase')} | Location: {result.get('location')}\")\n",
    "        print(f\"   Score: {score:.0%} | Verdict: {verdict_emoji.get(verdict, '❓')} {verdict}\")\n",
    "\n",
    "        if result.get(\"borderline_flag\"):\n",
    "            print(f\"   ⚠️  BORDERLINE — Physician review recommended\")\n",
    "\n",
    "        for c in assessment.get(\"criteria\", []):\n",
    "            emoji = outcome_emoji.get(c.get(\"outcome\", \"\"), \"—\")\n",
    "            ctype = \"INC\" if c.get(\"type\") == \"inclusion\" else \"EXC\"\n",
    "            print(f\"     {emoji} [{ctype}] {c.get('text', '')}\")\n",
    "            print(f\"        → {c.get('reasoning', '')}\")\n",
    "        print()\n",
    "\n",
    "\n",
    "display_results(str(response))"
   ]
  },
