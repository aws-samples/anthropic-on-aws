# ============================================================================
# Getting started with Claude Platform on AWS — notebook environment
# ============================================================================
# Copy this file to .env in the same directory and fill in real values.
# .env is gitignored. NEVER commit real keys.
#
#   cp .env.example .env
#   chmod 600 .env
#
# For the three-auth-paths reference, see the master doc:
#   launches/features/cp_on_aws/internal/cp-on-aws-master-reference.md
# ----------------------------------------------------------------------------

# ---- Short-term bearer token (12h lifetime) --------------------------------
# Paste from the Claude Platform on AWS console → API keys → "Generate short-term key".
# Format: aws-external-anthropic-api-key-<base64-presigned-url>
ANTHROPIC_AWS_API_KEY=aws-external-anthropic-api-key-...

# ---- Workspace ID ----------------------------------------------------------
# Find it in the CP-on-AWS console under "Workspaces", format: wrkspc_...
ANTHROPIC_AWS_WORKSPACE_ID=wrkspc_...

# ---- AWS region where your workspace lives ---------------------------------
AWS_REGION=us-east-2

# ---- Default model used throughout the notebook ----------------------------
# Haiku is cheapest; Sonnet gets the best balance of quality and cost.
CLAUDE_MODEL=claude-sonnet-4-6
