        <mxCell id="ecr" value="ECR (api/dkr endpoints)&#xa;claude-gateway · claude-bootstrap&#xa;scan-on-push" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DD3444;strokeColor=#B71C1C;fontColor=#ffffff;fontSize=9;" parent="1" vertex="1">
