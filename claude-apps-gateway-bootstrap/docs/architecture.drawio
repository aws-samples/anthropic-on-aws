        <mxCell id="s3cfg" value="S3 config bucket (versioned)&#xa;bootstrap-config.json — edit + push,&#xa;60s TTL, NO redeploy (config root of trust)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#7AA116;strokeColor=#558B2F;fontColor=#ffffff;fontSize=9;" parent="1" vertex="1">
          <mxGeometry x="1620" y="810" width="250" height="70" as="geometry" />
        </mxCell>
        <mxCell id="cw" value="CloudWatch (monitoring endpoint)&#xa;metrics: ClaudeCode (OTLP/EMF) · ClaudeGateway (spend)&#xa;· AWS/Bedrock (native) — logs: audit stream, /claude/otel/*&#xa;dashboard: claude-observability · alarm: spend-cap-80pct" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#B0084D;strokeColor=#7A0537;fontColor=#ffffff;fontSize=8;align=left;spacingLeft=6;" parent="1" vertex="1">
          <mxGeometry x="1500" y="890" width="370" height="86" as="geometry" />
        </mxCell>
        <mxCell id="iso" value="Isolated subnets (no egress) — 10.60.12.0/24 az-a · 10.60.13.0/24 az-b" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#FB8C00;dashed=1;verticalAlign=top;fontSize=11;fontColor=#E65100;" parent="1" vertex="1">
