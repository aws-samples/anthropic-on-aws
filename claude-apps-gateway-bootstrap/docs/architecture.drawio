        <mxCell id="dns" value="Route 53 split-horizon&#xa;PRIVATE zone (same name as your public zone): gateway host → ALB (private IPs, private network only)&#xa;PUBLIC zone validates the ACM cert only (gateway host never published)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDE7F6;strokeColor=#5E35B1;fontColor=#311B92;fontSize=9;align=left;spacingLeft=6;" parent="1" vertex="1">
