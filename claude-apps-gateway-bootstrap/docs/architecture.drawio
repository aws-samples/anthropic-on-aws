        <mxCell id="rds" value="RDS PostgreSQL 16 — db.t4g.micro, single-AZ, KMS-encrypted&#xa;sessions/device grants + SPEND TABLES (spend, spend_limits,&#xa;principal_emails, admin_audit) — SG 5432 ← Fargate SG only" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2E73B8;strokeColor=#1A4E7A;fontColor=#ffffff;fontSize=9;" parent="1" vertex="1">
          <mxGeometry x="760" y="1046" width="400" height="66" as="geometry" />
