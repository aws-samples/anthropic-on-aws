          <mxGeometry x="370" y="200" width="1560" height="1180" as="geometry" />
        </mxCell>
        <mxCell id="pub" value="Public subnets — NAT + Client VPN association only  (10.60.0.0/24 az-a · 10.60.1.0/24 az-b)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1E88E5;dashed=1;verticalAlign=top;fontSize=11;fontColor=#0D47A1;" parent="1" vertex="1">
          <mxGeometry x="390" y="250" width="1500" height="120" as="geometry" />
        </mxCell>
        <mxCell id="vpn" value="Client VPN endpoint&#xa;mutual TLS, split-tunnel&#xa;route 10.60.0.0/16&#xa;(or corporate VPN / DX / SD-WAN)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E7157B;strokeColor=#AD1457;fontColor=#ffffff;fontSize=9;" parent="1" vertex="1">
          <mxGeometry x="410" y="278" width="250" height="76" as="geometry" />
        </mxCell>
        <mxCell id="nat" value="NAT Gateway&#xa;(builder egress only)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E7157B;strokeColor=#AD1457;fontColor=#ffffff;fontSize=9;" parent="1" vertex="1">
          <mxGeometry x="1620" y="278" width="250" height="76" as="geometry" />
        </mxCell>
        <mxCell id="rules" value="HTTPS:443 listener (host = your gateway hostname)&#xa;• prio 5:  /user/bootstrap → Bootstrap :8081&#xa;• prio 7:  /v1/metrics · /v1/logs · /v1/traces → ADOT :4318&#xa;• prio 10: default → Gateway :8080" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3E5F5;strokeColor=#8C4FFF;fontColor=#4A148C;fontSize=9;align=left;spacingLeft=6;dashed=1;" parent="1" vertex="1">
          <mxGeometry x="520" y="428" width="360" height="80" as="geometry" />
        </mxCell>
        <mxCell id="alb" value="Internal ALB (IPv4-only)&#xa;ingress 443 ← VPN CIDR + spend Lambda SG&#xa;TLS: browser-trusted ACM public cert&#xa;for your gateway hostname" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#8C4FFF;strokeColor=#5E35B1;fontColor=#ffffff;fontSize=9;" parent="1" vertex="1">
          <mxGeometry x="420" y="600" width="240" height="110" as="geometry" />
        </mxCell>
        <mxCell id="gwtask" value="Gateway ECS task (Fargate, single task)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF8E1;strokeColor=#D97706;verticalAlign=top;fontStyle=1;fontSize=10;fontColor=#7A4F00;" parent="1" vertex="1">
          <mxGeometry x="740" y="530" width="320" height="190" as="geometry" />
        </mxCell>
        <mxCell id="gw" value="claude gateway :8080&#xa;Entra OIDC RP (device-code + browser)&#xa;managed policies (deny WebSearch, model allowlist)&#xa;admin: spend limits API + enforcement (429)&#xa;telemetry.forward_to → sidecar" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FF9900;strokeColor=#D97706;fontColor=#000000;fontSize=8;align=left;spacingLeft=6;" parent="gwtask" vertex="1">
          <mxGeometry x="10" y="26" width="300" height="86" as="geometry" />
        </mxCell>
        <mxCell id="otel" value="ADOT collector sidecar :4318 (essential:false)&#xa;otlp http → awsemf (ClaudeCode) + awscloudwatchlogs" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE0B2;strokeColor=#D97706;fontColor=#000000;fontSize=8;align=left;spacingLeft=6;" parent="gwtask" vertex="1">
          <mxGeometry x="10" y="122" width="300" height="56" as="geometry" />
        </mxCell>
        <mxCell id="bs" value="Bootstrap — Fargate :8081 (PKCE resource server)&#xa;validates Entra ACCESS token (JWKS+iss+aud+exp)&#xa;serves per-user config: MCP fleet (native URLs),&#xa;surface toggles, toolPolicy, egress allowlist, OTLP&#xa;endpoint · plugins via FILESYSTEM (no network delivery)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FF9900;strokeColor=#D97706;fontColor=#000000;fontSize=8;align=left;spacingLeft=6;" parent="1" vertex="1">
          <mxGeometry x="840" y="860" width="320" height="96" as="geometry" />
        </mxCell>
        <mxCell id="spendfn" value="Spend Lambdas ×2 (VPC, private subnets, read key)&#xa;• metrics: every 5 min GET /effective → CloudWatch&#xa;ns ClaudeGateway + 80%-of-cap alarm&#xa;• admin-MCP tools: invoked by AgentCore GW —&#xa;get_spend/top_spenders/caps/blocked (read-only)&#xa;(spend values: API returns CENTS; converted /100)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FF9900;strokeColor=#D97706;fontColor=#000000;fontSize=8;align=left;spacingLeft=6;" parent="1" vertex="1">
          <mxGeometry x="1040" y="760" width="300" height="80" as="geometry" />
        </mxCell>
        <mxCell id="builder" value="EC2 image builder (t4g.small)&#xa;no public IP, SSM-managed&#xa;builds+pushes both images (no local Docker)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FF9900;strokeColor=#D97706;fontColor=#000000;fontSize=9;" parent="1" vertex="1">
          <mxGeometry x="420" y="880" width="260" height="86" as="geometry" />
        </mxCell>
        <mxCell id="bedrock" value="Amazon Bedrock&#xa;au.anthropic.* profiles (opus-4-8, sonnet-4-6,&#xa;haiku-4-5) + global.anthropic.* (fable-5)&#xa;via bedrock-runtime VPC endpoint" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#01A88D;strokeColor=#00796B;fontColor=#ffffff;fontSize=9;" parent="1" vertex="1">
          <mxGeometry x="1620" y="468" width="250" height="80" as="geometry" />
        </mxCell>
        <mxCell id="secrets" value="Secrets Manager (VPC endpoint)&#xa;entra-client-secret · jwt-secret&#xa;postgres-url · admin-write-key&#xa;admin-read-key" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DD3444;strokeColor=#B71C1C;fontColor=#ffffff;fontSize=9;" parent="1" vertex="1">
          <mxGeometry x="1620" y="568" width="250" height="76" as="geometry" />
