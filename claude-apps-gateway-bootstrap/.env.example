# Claude bootstrap add-on — deployment configuration.
# Copy to .env and fill in from your deployed claude-apps-gateway stack
# (see README "Prerequisites" for where each value comes from):
#   cp .env.example .env

AWS_REGION=us-east-1

# ClaudeGatewayStack `PublicUrl` output, e.g. https://claude-gateway.internal.example.com
PUBLIC_URL=

# HTTPS :443 listener ARN of the gateway ALB (one-time lookup; see README)
LISTENER_ARN=

# Security-group id of the gateway ALB
ALB_SG_ID=

# VPC id the gateway stack deployed into
VPC_ID=

# Entra tenant ID (PKCE token issuer)
ENTRA_TENANT_ID=

# Entra app (client) ID of the Claude Desktop PKCE public client (README Step 1)
DESKTOP_CLIENT_ID=

# --- Optional: authorization gate (README "Restricting who receives configuration") ---
# Comma-separated. When set, a valid token must also carry a matching claim or the
# request is refused with 403. Leave empty to serve every valid tenant token.
#REQUIRED_GROUPS=
#REQUIRED_ROLES=
