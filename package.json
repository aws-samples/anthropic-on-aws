{
  "name": "anthropic-on-aws",
  "scripts": {
    "build": "mkdir -p dist/js && npm pack --pack-destination dist/js",
    "clobber": "BRANCH=$(git branch --show-current) && git checkout -b scratch && git checkout $BRANCH && git fetch origin && git reset --hard origin/$BRANCH && git clean -fdx",
    "upgrade": "yarn install --check-files && yarn upgrade commit-and-tag-version"
  },
  "devDependencies": {
    "commit-and-tag-version": "^12"
  },
  "devEngines": {
    "packageManager": {
      "name": "yarn",
      "version": "1.22.22",
      "onFail": "ignore"
    }
  },
  "main": "lib/index.js",
  "license": "MIT-0",
  "publishConfig": {
    "access": "public"
  },
  "version": "0.0.0"
}
