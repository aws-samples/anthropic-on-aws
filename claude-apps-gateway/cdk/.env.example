# Claude Gateway CDK Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# --- Gateway ---
GATEWAY_NAME=claude-gateway
GATEWAY_HOSTNAME=gateway.internal.yourcompany.com

# --- DNS (Route53) ---
HOSTED_ZONE_ID=ZXXXXXXXXXXXXXXXXX
HOSTED_ZONE_NAME=internal.yourcompany.com

# --- OIDC Identity Provider ---
OIDC_ISSUER=https://your-idp.example.com/
OIDC_CLIENT_ID=your-oidc-client-id
# Required. deploy.sh seeds this into Secrets Manager (never baked into the image)
# and refuses to deploy while it's still this placeholder. Register
# https://GATEWAY_HOSTNAME/oauth/callback on this OIDC client.
OIDC_CLIENT_SECRET=your-oidc-client-secret
ALLOWED_EMAIL_DOMAINS=yourcompany.com

# --- AWS / Bedrock ---
# Region whose Bedrock endpoint the gateway calls (the upstream `region:` in
# gateway.yaml + the inference-profile IAM ARN). Any Bedrock region works: the
# gateway uses GLOBAL cross-region inference profiles (global.anthropic.*), which
# resolve from any region. Note: global inference routes to any commercial AWS
# region — if you need data residency, see "Regions & data residency" in cdk/README.md.
BEDROCK_REGION=us-east-1

# Region the STACK deploys into (VPC, ALB, RDS, ECR, ECS, CodeBuild, S3).
# Optional — defaults to BEDROCK_REGION, so single-region users need not set it.
# deploy.sh exports this as AWS_REGION/AWS_DEFAULT_REGION so every aws CLI call and
# CDK agree on one region regardless of your shell's AWS_REGION. Pointing it at a
# different region from BEDROCK_REGION (cross-region Bedrock) is not fully
# supported yet — see the "Regions" note in cdk/README.md.
# DEPLOY_REGION=us-east-1

# --- TLS (imported ACM cert for GATEWAY_HOSTNAME) ---
# Required. Import a PUBLIC, browser-trusted cert so DNS validation needs no
# public endpoint (the ALB stays internal) and the CLI skips the fingerprint
# prompt on first /login. See the "TLS" section of cdk/README.md.
CERT_ARN=arn:aws:acm:us-east-1:123456789012:certificate/abc-123

# --- Network ingress ---
# Required. The VPN/corp CLIENT CIDR developers connect from — NOT the VPC CIDR.
INGRESS_CIDR=10.0.0.0/8

# --- Optional: reuse an existing VPC (e.g. to keep a Client VPN association intact) ---
# Leave unset to let CDK create a fresh VPC. If the reused VPC already has the
# Bedrock/Secrets Manager/ECR/CloudWatch/S3 interface endpoints, also set
# CREATE_VPC_ENDPOINTS=false — the stack refuses to recreate them.
# VPC_ID=vpc-0123456789abcdef0
# CREATE_VPC_ENDPOINTS=false
