# gateway.yaml.template — Claude apps gateway config for the AWS / Bedrock worked example.
#
# This file is COMMITTED. `stamp-config.sh` substitutes the build-time
# double-at placeholders below with real literal values (from deploy inputs) to
# produce `gateway.yaml`, which the Dockerfile COPYs into the image. Baking (vs. mounting)
# for why config is baked into the image on ECS rather than mounted as a secret file.
#
# Two kinds of placeholder appear here, and they are resolved at DIFFERENT times:
#
#   double-at  (PUBLIC_URL, AWS_REGION, ...) — BUILD time. Replaced by
#               stamp-config.sh before `docker build`. These are non-secret values
#               known at deploy and rarely changed (public_url, region, issuer,
#               client_id, email domains). Baking them means the image is
#               per-environment by design (baked config = one image per environment).
#
#   dollar-brace  ${NAME} — BOOT time. Expanded by the gateway itself when it reads
#               the file. Used for exactly two categories: secrets (never committed)
#               and values that don't exist until the deploy creates them (the RDS
#               endpoint + generated DB credentials). stamp-config.sh leaves these
#               untouched.
#
# Run the gateway with:  claude gateway --config /etc/claude/gateway.yaml
# Operational log verbosity is the CLAUDE_GATEWAY_LOG_LEVEL env var
# (info | warn | error; default info). It never affects audit events.

listen:
  host: 0.0.0.0
  port: 8080
  # The externally visible HTTPS origin. The gateway builds its OIDC redirect_uri
  # and discovery doc ONLY from this — never from X-Forwarded-* (those are
  # client-spoofable). Must resolve to PRIVATE IPs only on developer machines, or
  # `/login` rejects it. Here it is the internal ALB's hostname.
  public_url: @@PUBLIC_URL@@
  # The ALB terminates TLS (bring-your-own ACM cert), so the gateway speaks plain
  # HTTP behind it — no `tls:` block. Trust X-Forwarded-For only from the ALB so
  # real client IPs surface for per-IP rate limits and audit. Set to the ALB
  # subnet CIDRs (the private-subnet ranges the ALB ENIs live in).
  # trusted_proxies:
  #   - 10.0.0.0/8

oidc:
  # All three below are non-secret, known at deploy, and rarely change → baked.
  issuer: @@OIDC_ISSUER@@
  client_id: @@OIDC_CLIENT_ID@@
  client_secret: ${OIDC_CLIENT_SECRET}   # the one secret in this block (env-injected)
  allowed_email_domains: [@@ALLOWED_EMAIL_DOMAINS@@]
  # Per-IdP notes — uncomment what your provider needs:
  #   Okta (org server https://example.okta.com): id_token omits email/groups →
  #     userinfo_fallback: true
  #   Okta (custom server .../oauth2/default): emits claims directly, no fallback.
  #   Microsoft Entra: issuer https://login.microsoftonline.com/<tenant>/v2.0 ;
  #     groups arrive as Object IDs (GUIDs) — match on those, or use App Roles
  #     with `groups_claim: roles`.
  #   Keycloak / Dex behind corporate PKI: set `ca_cert_pem:`; lightweight access
  #     tokens need `userinfo_fallback: true`.
  # userinfo_fallback: true
  # Google-only: stamp-config.sh auto-fills the block below when the issuer is
  # accounts.google.com (Google rejects the default `offline_access` scope; refresh
  # tokens come from access_type=offline + prompt=consent instead). Non-Google
  # issuers stamp to nothing here and keep the default scopes.
@@OIDC_GOOGLE_BLOCK@@

session:
  jwt_secret: ${GATEWAY_JWT_SECRET}   # >= 32 bytes, e.g. `openssl rand -base64 32`
  # Bearer token lifetime. Default 1h is the secure choice: it assumes the IdP
  # issues refresh tokens (offline_access, in the default scopes), so the CLI
  # renews silently AND a disabled user loses access within <= 1h on the next
  # failed refresh.
  ttl_hours: 1
  # Refresh-token recipes by IdP:
  #   Okta / Entra: default `offline_access` scope suffices.
  #   Google: ignores offline_access — set, in the oidc block:
  #     scopes: [openid, profile, email]
  #     extra_auth_params: { access_type: offline, prompt: consent }
  # Opt-out: ONLY if your IdP can't issue refresh tokens, raise ttl_hours to 8-12
  # (no silent renewal otherwise) — deprovisioning then lags by that TTL.

store:
  # Credentials are split OUT of the URL (store.username/password take precedence
  # over any creds in the URL) so they stay in the RDS-generated secret. The host
  # is a deploy-created fact, so it's an env var, not baked; the db-name is baked.
  postgres_url: postgres://${DB_HOST}:5432/@@DB_NAME@@?sslmode=require
  username: ${DB_USER}
  password: ${DB_PASSWORD}
  # max_connections: 5   # keep replicas x this below RDS max_connections

upstreams:
  - provider: bedrock
    region: @@AWS_REGION@@
    auth: {}                 # AWS default credential chain → the ECS task role
    # FIPS / VPC-endpoint override:
    # base_url: https://bedrock-runtime-fips.@@AWS_REGION@@.amazonaws.com
  # Multi-upstream failover (provisioned-throughput → on-demand → second region).
  # Give each a distinct `name:`. On 2.1.198+ the gateway fails over on 5xx, 429,
  # 401, 403, 404, and timeout — so an upstream that hasn't enabled a model (404)
  # falls through to one that has; other 4xx (a bad request) does not. (Pre-2.1.198
  # returned the first 404 to the client instead of trying later upstreams.)
  # - name: bedrock-pt
  #   provider: bedrock
  #   region: @@AWS_REGION@@
  #   auth: {}
  # - name: bedrock-od
  #   provider: bedrock
  #   region: us-west-2
  #   auth: {}
  # (with a matching `models:` block mapping the PT ARN to bedrock-pt)
  #
  # Claude Platform on AWS (anthropicAws) — an alternative AWS-native upstream,
  # distinct from Bedrock: it serves the first-party Anthropic API on AWS at
  # aws-external-anthropic.<region>.api.aws, uses first-party model IDs, honors
  # anthropic-beta headers, and serves count_tokens — none of Bedrock's translation
  # applies. Requires CLAUDE_VERSION >= 2.1.198 (earlier gateways reject the provider
  # at boot). It runs in a SEPARATE AWS account and signs SigV4 for its own service
  # name (aws-external-anthropic), so the Bedrock-scoped task role does NOT authorize
  # it — use an API key, or grant the task role access to that service:
  # - provider: anthropicAws
  #   region: @@AWS_REGION@@
  #   workspace_id: wrkspc_...        # required; sent as a header on every request
  #   auth:
  #     api_key: ${ANTHROPIC_AWS_API_KEY}   # sent as x-api-key
  #   # OR SigV4 via the AWS default credential chain: auth: {}
  # (the built-in catalog routes here with no `models:` block, since it resolves
  #  first-party model IDs; if you curate `models:`, key the entry `anthropicAws:`)

telemetry:
  # Forwards straight to CloudWatch's native OTLP metrics endpoint — no collector
  # to run or maintain. Auth is a CloudWatch Metrics API key (bearer token; see
  # docs/deployment.md "Telemetry"), NOT SigV4: the gateway signs no requests, it
  # only attaches the static Authorization header below, and the metrics endpoint
  # accepts that as an alternative to SigV4 for workloads outside the AWS SDK.
  # Telemetry turns on only when forward_to AND listen.public_url are both set;
  # the gateway then pushes OTEL_* env to clients (one-time client approval dialog).
  forward_to:
    # No /v1/metrics suffix: the gateway appends the OTLP-standard signal path
    # itself (like any OTLP HTTP exporter), so a base URL that already ends in
    # /v1/metrics gets it doubled and 404s — see gotchas.md.
    - url: https://monitoring.@@AWS_REGION@@.amazonaws.com
      headers:
        Authorization: Bearer ${CW_METRICS_API_KEY}
      # Default is metrics-only. Metrics are aggregate counters (tokens, requests,
      # latency). The CloudWatch metrics OTLP endpoint doesn't accept logs/traces —
      # those need the separate logs (SigV4 or its own bearer token) or traces
      # (SigV4-only) endpoints, out of scope for this bearer-token setup.
      metrics: true

# Constrain the model picker to a curated allowlist. This turns the silent
# Bedrock AccessDenied trap into an explicit allowlist: align this with the
# Claude models you have ACTUALLY enabled access for, per region. Also enforced
# server-side at /v1/messages, so a patched client can't bypass it.
auto_include_builtin_models: true
managed:
  policies:
    # Example group-scoped policy (uncomment + adapt). Specific matches first;
    # they inherit any key they don't set from the match:{} base below.
    # - match: { groups: [eng-contractors] }
    #   cli:
    #     availableModels: [claude-haiku-4-5]
    #     enforceAvailableModels: true
    #     permissions: { allow: [Read, Grep] }
    # Per-team cost attribution: OTEL_RESOURCE_ATTRIBUTES is stamped on every
    # OTLP export, so CloudWatch's PromQL layer can group spend/usage by team
    # (sum by ("@resource.team.id") (...)) same as user.id/user.email already are.
    # - match: { groups: [team-platform] }
    #   cli:
    #     env:
    #       OTEL_RESOURCE_ATTRIBUTES: "team.id=platform,department=engineering,cost_center=cc-1001"
    # Catch-all base: matches every authenticated user.
    - match: {}
      cli:
        availableModels:
          - claude-opus-4-8
          - claude-sonnet-5
          - claude-haiku-4-5
          - claude-fable-5
        enforceAvailableModels: true

# Optional blocks, left commented:
