# Deployment variables for the standalone OTEL collector.
#
# Copy this file to `deploy.env`, fill in your real values, and keep it OUT of
# git (deploy.env is gitignored). Render and deploy the collector manifest with:
#
#   set -a && . ./deploy.env && set +a
#   envsubst < k8s/otel-collector.template.yaml | kubectl apply -f -
#
# See README-OTEL.md for the full walkthrough.

# AWS account ID that owns the cluster, IAM role, and CloudWatch metrics.
AWS_ACCOUNT_ID=123456789012

# Region of the EKS cluster / ALB / CloudWatch (e.g. ap-southeast-2, us-east-1).
AWS_REGION=us-east-1

# Collector hostname. MUST be covered by the ACM cert's SAN below (e.g. an
# otel.example.com covered by a *.example.com wildcard).
OTEL_HOST=otel.example.com

# ARN of the ACM certificate the internal ALB uses to terminate TLS.
ACM_CERT_ARN=arn:aws:acm:us-east-1:123456789012:certificate/00000000-0000-0000-0000-000000000000

# Comma-separated private subnet IDs for the internal ALB (reuse the gateway's).
ALB_SUBNETS=subnet-aaaaaaaaaaaaaaaaa,subnet-bbbbbbbbbbbbbbbbb

# S3 bucket that receives the ALB access logs (must exist with an ALB-log policy).
# Convention: claude-otel-alb-logs-<account-id>-<region>
ALB_LOGS_BUCKET=claude-otel-alb-logs-123456789012-us-east-1

# --- k8s/deployment.template.yaml + k8s/ingress.template.yaml ---

# One of the collector ALB's private IPs, for the gateway pod's hostAliases so it
# can reach the internal ALB by hostname. Get it with: dig +short <ALB_DNS_NAME>
# NOTE: internal ALB IPs change if the ALB is recreated — update this then re-apply.
ALB_PRIVATE_IP=10.0.0.10

# Gateway container image tag in your ECR repo (<account>.dkr.ecr.<region>...).
GATEWAY_IMAGE_TAG=2.1.196
